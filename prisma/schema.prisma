generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  slug     String    @unique
  imageUrl String?
  species  Species[]
}

model Species {
  id         String    @id @default(uuid())
  name       String    @unique
  slug       String    @unique
  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId String?
  createdAt  DateTime  @default(now())
  imageUrl   String?
  article    String?
  plants     Plant[]
}

model Plant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  article   Json?
  createdAt DateTime @default(now())
  species   Species? @relation(fields: [speciesId], references: [id])
  imageUrl  String?
  speciesId String?
}
