generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id     String  @id @default(uuid())
  name   String  @unique
  slug   String  @unique
  plants Plant[]
}

model Plant {
  id         String    @id @default(uuid())
  name       String
  slug       String    @unique
  article    Json?
  createdAt  DateTime  @default(now())
  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId String?
}
